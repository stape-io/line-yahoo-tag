    callLater(() => {
      assertApi('gtmOnSuccess').wasCalled();
      assertApi('gtmOnFailure').wasNotCalled();
      // The same generated ID should have been stored in the cookie.
      assertThat(anonCookieSetValue).isEqualTo(generatedId);
