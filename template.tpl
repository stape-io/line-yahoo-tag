setup: |-
  const JSON = require('JSON');
  const Promise = require('Promise');
  const parseUrl = require('parseUrl');
  const Object = require('Object');
  const makeInteger = require('makeInteger');
  const callLater = require('callLater');

  function assign() {
    const target = arguments[0];
    for (let i = 1; i < arguments.length; i++) {
      for (let key in arguments[i]) {
        target[key] = arguments[i][key];
      }
    }
    return target;
  }

  // ---------------------------------------------------------------------------
  // Default expected cookie options matching the tag's setCookies() logic
  // ---------------------------------------------------------------------------
  const expectedCookieOptions = {
    domain: 'auto',
    samesite: 'lax',
    path: '/',
    secure: true,
    httpOnly: false,
    'max-age': 60 * 60 * 24 * 365
  };

  // ---------------------------------------------------------------------------
  // Default event data that satisfies the "no early-exit" and "no-error" path:
  //   - has a page_location that is NOT the GTM preview endpoint
  //   - provides an anonymous ID so user data is never empty
  // ---------------------------------------------------------------------------
  mock('getAllEventData', () => ({
    event_name: 'page_view',
    page_location: 'https://example.com',
    _ly_su: 'default-anon-id'
  }));

  // Default: no cookies found (avoids cookie-based auto-mapping side-effects)
  mock('getCookieValues', () => []);

  // Default: container is NOT in debug/preview mode
  mock('getContainerVersion', () => ({ debugMode: false, previewMode: false }));

  // Default: sendHttpRequest resolves with 202
  mock('sendHttpRequest', (url, options, body) => {
    return Promise.create((resolve) => resolve({ statusCode: 202, headers: {}, body: '' }));
  });

  const NOW_MILISECONDS = 1747945830456;
  const NOW_SECONDS = 1747945830;
  mock('getTimestampMillis', NOW_MILISECONDS);

  // ---------------------------------------------------------------------------
