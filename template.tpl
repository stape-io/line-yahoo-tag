- name: '[Click ID Cookie] ly_c and ly_r source priority (both use getClickId)'
  code: |-
    // Priority: URL parameter (timestamped) > cookie > eventData._ly_x > eventData.ly_x
    // ly_c and ly_r share the same getClickId() function so we test both here.
    [
      {
        description: 'ly_c - URL param wins over cookie and eventData',
        idName: 'ly_c',
        disableCookies: { setAnonymousIdCookie: false, setComplementaryClickIdCookie: false },
        pageLocation: 'https://example.com/?_ly_c=from-url',
        eventData: { _ly_c: 'from-event-data', ly_c: 'from-event-data-no-prefix' },
        cookie: { name: '_ly_c', value: ['from-cookie'] },
        assertFn: (value) => assertThat(value.indexOf('from-url')).isGreaterThan(-1)
      },
      {
        description: 'ly_c - cookie wins over eventData when no URL',
        idName: 'ly_c',
        disableCookies: { setAnonymousIdCookie: false, setComplementaryClickIdCookie: false },
        pageLocation: 'https://example.com/',
        eventData: { _ly_c: 'from-event-data', ly_c: 'from-event-data-no-prefix' },
        cookie: { name: '_ly_c', value: ['from-cookie'] },
        assertFn: (value) => assertThat(value).isEqualTo('from-cookie')
      },
      {
        description: 'ly_c - eventData (prefixed) wins over eventData (no prefix)',
        idName: 'ly_c',
        disableCookies: { setAnonymousIdCookie: false, setComplementaryClickIdCookie: false },
        pageLocation: 'https://example.com/',
        eventData: { _ly_c: 'from-prefixed', ly_c: 'from-no-prefix' },
        cookie: undefined,
        assertFn: (value) => assertThat(value).isEqualTo('from-prefixed')
      },
      {
        description: 'ly_r - URL param wins over cookie and eventData',
        idName: 'ly_r',
        disableCookies: { setAnonymousIdCookie: false, setClickIdCookie: false },
        pageLocation: 'https://example.com/?_ly_r=from-url',
        eventData: { _ly_r: 'from-event-data', ly_r: 'from-event-data-no-prefix' },
        cookie: { name: '_ly_r', value: ['from-cookie'] },
        assertFn: (value) => assertThat(value.indexOf('from-url')).isGreaterThan(-1)
      }
    ].forEach((scenario) => {
      mockData.autoMapUserIdentifiersParameters = true;
      mockData.userIdentifiersParametersList = undefined;
      for (const key in scenario.disableCookies) mockData[key] = scenario.disableCookies[key];

      const eventDataOverrides = { page_location: scenario.pageLocation };
      for (const key in scenario.eventData) eventDataOverrides[key] = scenario.eventData[key];
      mock('getAllEventData', () => assign({ event_name: 'page_view' }, eventDataOverrides));

      mock('getCookieValues', (name) => {
        if (scenario.cookie && name === scenario.cookie.name) return scenario.cookie.value;
        return [];
      });

      mock('sendHttpRequest', (url, options, body) => {
        const parsed = JSON.parse(body);
        scenario.assertFn(parsed.data[0].user[scenario.idName]);
        return Promise.create((resolve) => resolve({ statusCode: 202 }));
      });

      runCode(mockData);

      callLater(() => {
        assertApi('gtmOnSuccess').wasCalled();
        assertApi('gtmOnFailure').wasNotCalled();
      });
    });
